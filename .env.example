# Server
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=document_reminder

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Email (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=Document Reminder <your_email@gmail.com>

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# App
LOGO_URL=https://yourdomain.com/logo.png

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Firebase Cloud Messaging (FCM) — Push Notifications
# Option 1: paste the full service-account JSON as a single-line string
FIREBASE_SERVICE_ACCOUNT_JSON=

# Option 2: individual fields from the service-account JSON (used if FIREBASE_SERVICE_ACCOUNT_JSON is empty)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
